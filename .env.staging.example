# Staging Environment
# Get these values from your STAGING Supabase project dashboard: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=your_staging_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_staging_supabase_anon_key
